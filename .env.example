# Copy to .env.local for local development. Never commit real secrets.
# On Vercel these are provisioned automatically by `npm run bootstrap`
# (Marketplace integrations) and pulled with `vercel env pull .env.local`.

# --- Site ---
# Public canonical origin. Falls back to the Vercel deployment URL if unset.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Payload ---
# High-entropy secret used to sign Payload tokens. Generate with:
#   node -e "console.log(require('node:crypto').randomBytes(32).toString('base64url'))"
PAYLOAD_SECRET=

# --- Database (Neon Postgres via Vercel Marketplace) ---
# Auto-provisioned by the Neon integration. The vercel-postgres adapter reads
# POSTGRES_URL by default; DATABASE_URL is accepted as an alias.
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
DATABASE_URL=

# --- Media storage (Vercel Blob) ---
BLOB_READ_WRITE_TOKEN=

# --- Lead delivery (provider-neutral; only one adapter is required) ---
# Supported LEAD_TRANSPORT values: "log" (default, dev), "resend", "smtp".
LEAD_TRANSPORT=log
LEAD_NOTIFICATION_TO=info@aiio.de
LEAD_NOTIFICATION_FROM=website@aiio.de
RESEND_API_KEY=

# --- First-run admin bootstrap (temporary; remove/rotate after first login) ---
PAYLOAD_BOOTSTRAP_ADMIN_EMAIL=
PAYLOAD_BOOTSTRAP_ADMIN_PASSWORD=
