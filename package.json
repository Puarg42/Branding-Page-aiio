{
  "name": "aiio-website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "theory:compile": "node scripts/compile-theory.mjs",
    "theory:check": "node scripts/compile-theory.mjs --check",
    "ci:build": "node scripts/ci-build.mjs",
    "brand-review": "node scripts/review/export-brand-review.mjs",
    "payload": "payload",
    "bootstrap": "node --import tsx scripts/bootstrap.mjs",
    "db:migrate": "payload migrate",
    "db:migrate:create": "payload migrate:create",
    "db:status": "payload migrate:status",
    "db:seed": "dotenv -e .env.local -- tsx scripts/seed.ts",
    "db:reset:test": "dotenv -e .env.test.local -- tsx scripts/reset-test-db.ts",
    "content:import": "dotenv -e .env.local -- tsx scripts/import-content.ts",
    "content:copy-de-to-en": "dotenv -e .env.local -- tsx scripts/copy-locale-content.ts",
    "generate:types": "payload generate:types",
    "generate:importmap": "payload generate:importmap",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@payloadcms/db-vercel-postgres": "^3.85.1",
    "@payloadcms/live-preview-react": "^3.86.0",
    "@payloadcms/next": "^3.85.1",
    "@payloadcms/richtext-lexical": "^3.85.1",
    "@payloadcms/storage-vercel-blob": "^3.85.1",
    "@payloadcms/ui": "^3.85.1",
    "framer-motion": "^12.42.0",
    "graphql": "^16.11.0",
    "next": "16.2.6",
    "payload": "^3.85.1",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "sharp": "^0.34.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/jsdom": "^21.1.7",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "dotenv-cli": "^8.0.0",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "jsdom": "^26.1.0",
    "playwright": "^1.61.1",
    "tailwindcss": "4.2.1",
    "tsx": "^4.20.6",
    "typescript": "5.9.3",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "dompurify": "^3.4.12",
    "postcss": "^8.5.19",
    "esbuild": "0.28.1"
  }
}
